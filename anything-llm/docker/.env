# ── AnythingLLM Base Settings ──
SERVER_PORT=3001
STORAGE_DIR="/app/server/storage"
UID=1000
GID=1000

# ── LLM Provider: Ollama (runs in a sibling container) ──
LLM_PROVIDER=ollama
# Service name "ollama" resolves via Docker's internal DNS
OLLAMA_BASE_PATH=http://ollama:11434

# ═══════════════════════════════════════════════
# EASY MODEL SWAP — change this one line:
OLLAMA_MODEL=gemma4:latest
# Examples: llama3.2:latest, mistral:latest, qwen2.5:latest
# Then: docker compose -f docker/docker-compose.yml up -d
# ═══════════════════════════════════════════════

OLLAMA_MODEL_TOKEN_LIMIT=8192
# OLLAMA_AUTH_TOKEN=''

# ── Embedding (also uses Ollama) ──
EMBEDDING_ENGINE=ollama
EMBEDDING_BASE_PATH=http://ollama:11434
EMBEDDING_MODEL_PREF=nomic-embed-text:latest
EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192

# ── Vector DB ──
VECTOR_DB=lancedb

# ── Audio / TTS ──
WHISPER_PROVIDER=local
TTS_PROVIDER=native

# ── Security ──
PASSWORDMINCHAR=8

# ── Ollama container settings ──
# Change this if you want a different Ollama image tag
OLLAMA_IMAGE=ollama/ollama:latest
